{
  "name": "ralph-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite build --watch --config web/vite.config.ts",
    "build": "tsc -p server/tsconfig.json && vite build --config web/vite.config.ts",
    "start": "node dist/server/server/src/index.js"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "@tanstack/react-query": "5.100.11",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fastify": "5.8.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.15.1",
    "tailwind-merge": "3.6.0",
    "ws": "8.20.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "5.1.1",
    "autoprefixer": "10.5.0",
    "concurrently": "9.2.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.18",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vite": "7.3.2"
  }
}
